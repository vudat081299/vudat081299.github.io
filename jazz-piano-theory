    ];
    mkBtns('altBtns',defs,function(d){ seqPlay([{bass:43,notes:d.up},{bass:48,notes:[64,67,71,74]}],1.15); roB.innerHTML='<b>'+d.label+'</b> — '+d.t+' Nghe lực căng rồi nhả về Cmaj7.'; });
  }
  const roU=document.getElementById('usReadout'); if(document.getElementById('usBtns')){
    const defs=[
      {label:'Rê trưởng / C7', notes:[48,64,70,62,66,69], t:'tay trái C7 (C-E-B♭), tay phải hợp âm Rê trưởng → C13♯11, màu "phim".'},
      {label:'La♭ trưởng / G7', notes:[43,59,65,56,60,63], t:'tay trái G7, tay phải hợp âm La♭ trưởng → G7 với ♭9/♭13, chất altered.'}
    ];
