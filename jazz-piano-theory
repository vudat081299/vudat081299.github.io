<script>
"use strict";
/* ===================== AUDIO ENGINE ===================== */
let AC=null, master=null, comp=null, noiseBuf=null;
function audio(){
  if(!AC){
    AC=new (window.AudioContext||window.webkitAudioContext)();
    master=AC.createGain(); master.gain.value=0.85;
    comp=AC.createDynamicsCompressor();
    comp.threshold.value=-18; comp.ratio.value=4; comp.attack.value=0.003; comp.release.value=0.25;
    master.connect(comp); comp.connect(AC.destination);
  }
  if(AC.state==='suspended') AC.resume();
  return AC;
}
function markAudioOn(){ const cta=document.getElementById('audioCta'); if(cta&&!cta.classList.contains('on')){ cta.classList.add('on'); const b=document.getElementById('enableAudio'); if(b){ b.textContent='Tiếng đã bật ✓'; b.disabled=true; b.style.opacity=.7; } } }
function mtof(m){ return 440*Math.pow(2,(m-69)/12); }
function noise(){ if(!noiseBuf){ const ac=audio(); noiseBuf=ac.createBuffer(1, ac.sampleRate, ac.sampleRate); const d=noiseBuf.getChannelData(0); for(let i=0;i<d.length;i++) d[i]=Math.random()*2-1; } return noiseBuf; }
function voice(midi,t0,dur,vel){
  const ac=audio(); vel=vel==null?0.8:vel; const f=mtof(midi);
  const g=ac.createGain();
  const peak=0.20*vel, sus=Math.max(0.0001,peak*0.30);
  g.gain.setValueAtTime(0.0001,t0);
  g.gain.exponentialRampToValueAtTime(peak,t0+0.006);
  g.gain.exponentialRampToValueAtTime(sus,t0+0.28);
  g.gain.exponentialRampToValueAtTime(0.0001,t0+dur);
  const lp=ac.createBiquadFilter(); lp.type='lowpass';
  lp.frequency.setValueAtTime(Math.min(11000,f*7),t0);
  lp.frequency.exponentialRampToValueAtTime(Math.min(9000,f*3+400),t0+dur);
  const o1=ac.createOscillator(); o1.type='triangle'; o1.frequency.value=f;
  const o2=ac.createOscillator(); o2.type='sine'; o2.frequency.value=f*2; const o2g=ac.createGain(); o2g.gain.value=0.32;
  const o3=ac.createOscillator(); o3.type='sine'; o3.frequency.value=f*0.5; const o3g=ac.createGain(); o3g.gain.value=0.18;
  o1.connect(lp); o2.connect(o2g); o2g.connect(lp); o3.connect(o3g); o3g.connect(lp); lp.connect(g); g.connect(master);
  o1.start(t0); o2.start(t0); o3.start(t0);
  const end=t0+dur+0.06; o1.stop(end); o2.stop(end); o3.stop(end);
}
function chord(ms,t0,dur,vel){ ms.forEach(m=>voice(m,t0,dur,vel)); }
function arp(ms,t0,step,dur,vel){ ms.forEach((m,i)=>voice(m,t0+i*step,dur,vel)); }
function kick(t0,vel){ const ac=audio(); vel=vel||1; const o=ac.createOscillator(); const g=ac.createGain();
  o.frequency.setValueAtTime(135,t0); o.frequency.exponentialRampToValueAtTime(45,t0+0.11);
  g.gain.setValueAtTime(0.9*vel,t0); g.gain.exponentialRampToValueAtTime(0.001,t0+0.26);
  o.connect(g); g.connect(master); o.start(t0); o.stop(t0+0.28); }
function snare(t0,vel){ const ac=audio(); vel=vel||1;
  const s=ac.createBufferSource(); s.buffer=noise(); const hp=ac.createBiquadFilter(); hp.type='highpass'; hp.frequency.value=1400;
  const g=ac.createGain(); g.gain.setValueAtTime(0.45*vel,t0); g.gain.exponentialRampToValueAtTime(0.001,t0+0.18);
  s.connect(hp); hp.connect(g); g.connect(master); s.start(t0); s.stop(t0+0.2);
  const o=ac.createOscillator(); o.type='triangle'; o.frequency.value=190; const g2=ac.createGain();
  g2.gain.setValueAtTime(0.22*vel,t0); g2.gain.exponentialRampToValueAtTime(0.001,t0+0.12); o.connect(g2); g2.connect(master); o.start(t0); o.stop(t0+0.13); }
function hat(t0,vel,open){ const ac=audio(); vel=vel||1; const dur=open?0.28:0.045;
  const s=ac.createBufferSource(); s.buffer=noise(); const hp=ac.createBiquadFilter(); hp.type='highpass'; hp.frequency.value=7000;
  const g=ac.createGain(); g.gain.setValueAtTime(0.24*vel,t0); g.gain.exponentialRampToValueAtTime(0.001,t0+dur);
  s.connect(hp); hp.connect(g); g.connect(master); s.start(t0); s.stop(t0+dur+0.02); }
function clap(t0,vel){ const ac=audio(); vel=vel||1; const s=ac.createBufferSource(); s.buffer=noise();
  const bp=ac.createBiquadFilter(); bp.type='bandpass'; bp.frequency.value=1600; bp.Q.value=1.2;
  const g=ac.createGain(); g.gain.setValueAtTime(0.5*vel,t0); g.gain.exponentialRampToValueAtTime(0.001,t0+0.15);
  s.connect(bp); bp.connect(g); g.connect(master); s.start(t0); s.stop(t0+0.16); }
function click(t0,strong){ const ac=audio(); const o=ac.createOscillator(); const g=ac.createGain();
  o.frequency.value=strong?1500:1000; g.gain.setValueAtTime(0.0001,t0); g.gain.exponentialRampToValueAtTime(strong?0.5:0.28,t0+0.001);
  g.gain.exponentialRampToValueAtTime(0.0001,t0+0.05); o.connect(g); g.connect(master); o.start(t0); o.stop(t0+0.06); }

/* ===================== NOTE NAMES ===================== */
const EN=['C','C♯','D','D♯','E','F','F♯','G','G♯','A','A♯','B'];
const VN=['Đô','Đô♯','Rê','Rê♯','Mi','Fa','Fa♯','Sol','Sol♯','La','La♯','Si'];
function nmeN(m){ return EN[((m%12)+12)%12]+(Math.floor(m/12)-1); }
function setPlaying(btn,on){ if(btn) btn.classList.toggle('playing',on); }

/* ===== INTRO document modules ===== */

/* ===================== 1. PIANO ===================== */
(function(){
  const piano=document.getElementById('piano'); if(!piano) return;
  const LO=60, HI=83;
  const isBlack=m=>[1,3,6,8,10].includes(((m%12)+12)%12);
  const whites=[]; for(let m=LO;m<=HI;m++) if(!isBlack(m)) whites.push(m);
  const wEls={};
  whites.forEach(m=>{
    const el=document.createElement('div'); el.className='wkey'; el.dataset.midi=m;
    el.innerHTML='<span class="lbl">'+EN[m%12]+'<span class="vn">'+VN[m%12]+'</span></span>';
    piano.appendChild(el); wEls[m]=el;
  });
  const blackEls={};
  for(let m=LO;m<=HI;m++){ if(!isBlack(m)) continue;
    const leftW=m-1, i=whites.indexOf(leftW); if(i<0) continue;
    const b=document.createElement('div'); b.className='bkey'; b.dataset.midi=m;
    b.style.left=((i+1)/whites.length*100)+'%'; b.style.width=(100/whites.length*0.62)+'%';
    b.innerHTML='<span class="lbl">'+EN[m%12]+'</span>';
    piano.appendChild(b); blackEls[m]=b;
  }
  const kmap={'a':60,'w':61,'s':62,'e':63,'d':64,'f':65,'t':66,'g':67,'y':68,'h':69,'u':70,'j':71,'k':72,'o':73,'l':74,'p':75};
  const staff=document.getElementById('staff'), nowNote=document.getElementById('nowNote');
  function drawStaff(midi){
    const x0=40,x1=190,top=30,gap=12; let s='';
    for(let i=0;i<5;i++){ const y=top+i*gap; s+='<line x1="'+x0+'" y1="'+y+'" x2="'+x1+'" y2="'+y+'" stroke="var(--border)" stroke-width="1"/>'; }
    s+='<text x="16" y="'+(top+34)+'" font-family="serif" font-size="46" fill="var(--text-muted)">&#119070;</text>';
    if(midi!=null){
      const diatonic={0:0,2:1,4:2,5:3,7:4,9:5,11:6};
      const pc=((midi%12)+12)%12, oct=Math.floor(midi/12)-1;
      let step, sharp=false; const base=diatonic[pc];
      if(base!==undefined){ step=base; } else { step=diatonic[pc-1]; sharp=true; }
      const idx=(oct*7)+step, ref=(4*7)+2;
      const bottomY=top+4*gap, cy=bottomY-(idx-ref)*(gap/2), cx=120;
      const topLineY=top, botLineY=top+4*gap;
      if(cy>botLineY){ for(let yy=botLineY+gap; yy<=cy+0.1; yy+=gap) s+='<line x1="'+(cx-11)+'" y1="'+yy+'" x2="'+(cx+11)+'" y2="'+yy+'" stroke="var(--border)"/>'; }
      if(cy<topLineY){ for(let yy=topLineY-gap; yy>=cy-0.1; yy-=gap) s+='<line x1="'+(cx-11)+'" y1="'+yy+'" x2="'+(cx+11)+'" y2="'+yy+'" stroke="var(--border)"/>'; }
      s+='<ellipse cx="'+cx+'" cy="'+cy+'" rx="7.5" ry="5.5" fill="var(--accent-identity)" transform="rotate(-18 '+cx+' '+cy+')"/>';
      if(sharp) s+='<text x="'+(cx-24)+'" y="'+(cy+5)+'" font-size="16" fill="var(--accent-identity)" font-family="serif">&#9839;</text>';
    }
    staff.innerHTML=s;
  }
  function hit(midi){
    voice(midi, audio().currentTime, 1.6, 0.85); markAudioOn();
    nowNote.innerHTML=EN[midi%12]+'<small>'+VN[midi%12]+' · '+nmeN(midi)+'</small>';
    drawStaff(midi);
    const el=wEls[midi]||blackEls[midi]; if(el){ el.classList.add('down'); setTimeout(()=>el.classList.remove('down'),140); }
  }
  drawStaff(null);
  piano.addEventListener('pointerdown',e=>{ const k=e.target.closest('[data-midi]'); if(k){ e.preventDefault(); hit(+k.dataset.midi); } });
  window.addEventListener('keydown',e=>{
    if(e.repeat||e.metaKey||e.ctrlKey||e.altKey) return;
    if(document.activeElement&&/INPUT|TEXTAREA/.test(document.activeElement.tagName)) return;
    const m=kmap[e.key.toLowerCase()]; if(m!=null){ hit(m); }
  });
})();

/* ===================== 2A. METER ===================== */
(function(){
  const seg=document.getElementById('meterSeg'), playB=document.getElementById('meterPlay');
  const bpm=document.getElementById('meterBpm'), bpmV=document.getElementById('meterBpmV'), row=document.getElementById('pulseRow');
  if(!seg) return; let meter=4, timer=null, playing=false;
  function build(){ row.innerHTML=''; const beats=meter===6?6:meter; for(let i=0;i<beats;i++){ const d=document.createElement('div'); d.className='pdot'+((i===0||(meter===6&&i===3))?' strong':''); d.textContent=(i+1); row.appendChild(d); } }
  build();
  seg.addEventListener('click',e=>{ const b=e.target.closest('button'); if(!b) return; seg.querySelectorAll('button').forEach(x=>x.classList.remove('on')); b.classList.add('on'); meter=+b.dataset.m; build(); });
  bpm.addEventListener('input',()=>bpmV.textContent=bpm.value+' BPM');
  function stop(){ playing=false; clearInterval(timer); setPlaying(playB,false); playB.textContent='▶ Phát'; [].forEach.call(row.children,d=>d.classList.remove('hit')); }
  playB.addEventListener('click',()=>{
    if(playing){ stop(); return; }
    audio(); markAudioOn(); playing=true; setPlaying(playB,true); playB.textContent='■ Dừng';
    const beats=meter===6?6:meter; const spb=60/(+bpm.value)*(meter===6?0.5:1); let i=0;
    const tick=()=>{ const strong=(i===0||(meter===6&&i===3)); const ac=audio();
      if(meter===6){ voice(strong?67:60, ac.currentTime,0.12,strong?0.9:0.5); } else { click(ac.currentTime,strong); if(strong) kick(ac.currentTime,0.7); }
      [].forEach.call(row.children,d=>d.classList.remove('hit')); const d=row.children[i]; if(d) d.classList.add('hit');
      i=(i+1)%beats; };
    tick(); timer=setInterval(tick, spb*1000);
  });
})();

/* ===================== 2B. CLAP 1&3 vs 2&4 ===================== */
(function(){
  const bW=document.getElementById('clapWrong'), bR=document.getElementById('clapRight'), bS=document.getElementById('clapStop');
  if(!bW) return; let timer=null, step=0, mode=null;
  function stop(){ clearInterval(timer); timer=null; setPlaying(bW,false); setPlaying(bR,false); }
  function start(which,btn){ stop(); audio(); markAudioOn(); mode=which; step=0; setPlaying(btn,true);
    const sp=60/96/2*1000;
    const tick=()=>{ const ac=audio(); const b=step%8;
      if(b%2===0) hat(ac.currentTime,0.5);
      if(b===0||b===4) kick(ac.currentTime,0.9);
      const beat=b/2;
      if(Number.isInteger(beat)){
        if(mode==='wrong' && (beat===0||beat===2)) clap(ac.currentTime,0.9);
        if(mode==='right' && (beat===1||beat===3)) clap(ac.currentTime,0.9);
      }
      step++; };
    tick(); timer=setInterval(tick,sp);
  }
  bW.addEventListener('click',()=>{ if(mode==='wrong'&&timer){stop();mode=null;return;} start('wrong',bW); });
  bR.addEventListener('click',()=>{ if(mode==='right'&&timer){stop();mode=null;return;} start('right',bR); });
  bS.addEventListener('click',()=>{ stop(); mode=null; });
})();

/* ===================== 2C. TAP TRAINER ===================== */
(function(){
  const startB=document.getElementById('tapStart'), stopB=document.getElementById('tapStop'), pad=document.getElementById('tapPad');
  const bpm=document.getElementById('tapBpm'), bpmV=document.getElementById('tapBpmV'), fb=document.getElementById('tapFb');
  if(!startB) return; let timer=null, running=false, beatTimes=[], spb=0;
  bpm.addEventListener('input',()=>bpmV.textContent=bpm.value+' BPM');
  function stop(){ running=false; clearInterval(timer); setPlaying(startB,false); startB.textContent='▶ Bật máy đếm'; }
  startB.addEventListener('click',()=>{
    if(running){ stop(); return; }
    audio(); markAudioOn(); running=true; setPlaying(startB,true); startB.textContent='■ Đang chạy'; beatTimes=[];
    spb=60/(+bpm.value); let i=0;
    const tick=()=>{ const t=audio().currentTime; click(t, i%4===0); beatTimes.push(t); if(beatTimes.length>16) beatTimes.shift(); i++; };
    tick(); timer=setInterval(tick, spb*1000);
    fb.innerHTML='<span class="muted">Đang đếm… gõ theo tiếng click.</span>';
  });
  stopB.addEventListener('click',stop);
  function tap(){
    if(!running){ fb.innerHTML='<span class="muted">Bật máy đếm trước đã.</span>'; return; }
    const t=audio().currentTime; if(!beatTimes.length) return;
    let ref=beatTimes[beatTimes.length-1]; let err=((t-ref)%spb); if(err>spb/2) err-=spb; if(err<-spb/2) err+=spb;
    const ms=Math.round(err*1000); const a=Math.abs(ms);
    let cls,txt; if(a<=45){cls='fb-tight';txt='KHỚP 🎯';} else if(ms<0){cls='fb-early';txt='HƠI SỚM';} else {cls='fb-late';txt='HƠI TRỄ';}
    fb.innerHTML='<span class="val '+cls+'">'+txt+'</span><span class="muted">lệch '+(ms>0?'+':'')+ms+' ms so với phách gần nhất</span>';
    pad.style.transform='scale(0.98)'; setTimeout(()=>pad.style.transform='',80);
  }
  pad.addEventListener('pointerdown',e=>{e.preventDefault();tap();});
  window.addEventListener('keydown',e=>{ if(e.code==='Space' && running){ if(document.activeElement&&/INPUT|TEXTAREA/.test(document.activeElement.tagName))return; e.preventDefault(); tap(); } });
})();

