let progTimer=null, progBtnActive=null;
function stopProg(){ if(progTimer){clearTimeout(progTimer);progTimer=null;} setPlaying(progBtnActive,false); progBtnActive=null; }
function playProgression(chords, bpm, btn, swing){
  stopProg(); audio(); markAudioOn(); progBtnActive=btn; setPlaying(btn,true);
  const spb=60/bpm, beatsPer=2; let i=0;
  function step(){
    if(i>=chords.length){ setPlaying(btn,false); progBtnActive=null; progTimer=null; return; }
    const t=audio().currentTime+0.02, c=chords[i], dur=spb*beatsPer;
    voice(c[0]-12,t,dur,0.55);
    chord(c.slice(1),t,dur*0.95,0.55);
    if(swing){ hat(t,0.4); hat(t+spb*0.66,0.3); hat(t+spb,0.4); hat(t+spb*1.66,0.3); }
    i++; progTimer=setTimeout(step,dur*1000);
  }
  step();
}
