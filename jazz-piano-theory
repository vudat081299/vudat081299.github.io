/* ===================== DOC TABS · NAV · PROGRESS · THEME (merged, per-document) ===================== */
(function(){
  const tabs=[].slice.call(document.querySelectorAll('.doctab'));
  const docs=[].slice.call(document.querySelectorAll('.doc'));
  const nav=document.getElementById('sbNav');
  function activeDoc(){ return document.querySelector('.doc.on') || docs[0]; }

  function buildNav(docEl){
    if(!nav||!docEl) return;
    nav.innerHTML='';
    const secs=[].slice.call(docEl.querySelectorAll('section[data-title]'));
    const ov=docEl.querySelector('.overview-map'); if(ov) ov.innerHTML='';
    secs.forEach(function(s,i){
      const k=String(i).padStart(2,'0'), title=s.getAttribute('data-title');
      const a=document.createElement('a'); a.className='sb-link'; a.href='#';
      a.innerHTML='<span class="k">'+k+'</span><span>'+title+'</span>';
      a.addEventListener('click',function(e){ e.preventDefault(); s.scrollIntoView({behavior:'smooth',block:'start'});
        if(!window.matchMedia('(min-width:1025px)').matches) document.body.classList.remove('nav-open'); });
      nav.appendChild(a); s._navlink=a;
      if(ov && !s.classList.contains('overview')){ const li=document.createElement('li'); const oa=document.createElement('a'); oa.href='#';
        oa.innerHTML='<span class="mk">'+k+'</span><span>'+title+'</span>';
        oa.addEventListener('click',function(e){ e.preventDefault(); s.scrollIntoView({behavior:'smooth',block:'start'}); });
        li.appendChild(oa); ov.appendChild(li); }
    });
  }

  const rp=document.getElementById('rp'), fill=document.getElementById('progFill'), pct=document.getElementById('progPct');
  let ticking=false;
  function update(){
    ticking=false;
    const st=window.pageYOffset||document.documentElement.scrollTop;
    const docH=(document.documentElement.scrollHeight-window.innerHeight)||1;
    const p=Math.max(0,Math.min(1,st/docH)); const pStr=Math.round(p*100)+'%';
    if(rp) rp.style.width=pStr; if(fill) fill.style.width=pStr; if(pct) pct.textContent=pStr;
    const docEl=activeDoc(); if(!docEl) return;
    const secs=[].slice.call(docEl.querySelectorAll('section[data-title]'));
    let activeSec=secs.length?secs[0]:null;
    secs.forEach(function(s){ const r=s.getBoundingClientRect(); if(r.top<=150) activeSec=s; });
    secs.forEach(function(s){ const a=s._navlink; if(!a) return; const r=s.getBoundingClientRect();
      a.classList.toggle('active', s===activeSec);
      a.classList.toggle('done', r.bottom<150 && s!==activeSec); });
  }
  function onScroll(){ if(!ticking){ ticking=true; requestAnimationFrame(update); } }
  window.addEventListener('scroll',onScroll,{passive:true});
  window.addEventListener('resize',onScroll);

  function switchDoc(id){
    docs.forEach(function(d){ d.classList.toggle('on', d.id===id); });
    tabs.forEach(function(t){ t.classList.toggle('on', t.getAttribute('data-doc')===id); });
    buildNav(document.getElementById(id));
    window.scrollTo(0,0); update();
  }
  tabs.forEach(function(t){ t.addEventListener('click',function(){ switchDoc(t.getAttribute('data-doc')); }); });

  const toggle=document.getElementById('sbToggle'), backdrop=document.getElementById('backdrop');
  if(toggle) toggle.addEventListener('click',function(){ document.body.classList.toggle('nav-open'); });
  if(backdrop) backdrop.addEventListener('click',function(){ document.body.classList.remove('nav-open'); });
  if(window.matchMedia('(min-width:1025px)').matches) document.body.classList.add('nav-open');

  const tBtn=document.getElementById('themeToggle'), tLbl=document.getElementById('themeLbl');
  function applyTheme(mode){ document.documentElement.setAttribute('data-theme',mode);
    if(tLbl) tLbl.textContent=(mode==='dark')?'Tối':'Sáng';
    if(tBtn) tBtn.firstChild.textContent=(mode==='dark')?'🌙 ':'☀️ '; }
  try{ const saved=localStorage.getItem('nlp-theme'); if(saved) applyTheme(saved); else applyTheme('dark'); }catch(e){ applyTheme('dark'); }
  if(tBtn) tBtn.addEventListener('click',function(){
    const cur=document.documentElement.getAttribute('data-theme')||'dark';
    const next=(cur==='dark')?'light':'dark'; applyTheme(next);
    try{ localStorage.setItem('nlp-theme',next); }catch(e){}
  });

  buildNav(activeDoc()); update();
})();

