<!DOCTYPE html>
<html lang="vi" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="color-scheme" content="dark light">
<title>Nhạc lý → Piano → Jazz · trọn bộ</title>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap">
<style>
:root{
  --bg:#0a0a0f; --surface:#111118; --card:#16161f; --border:#2a2a3a; --hairline:rgba(255,255,255,0.04);
  --text-primary:#f0f0f8; --text-secondary:#a8a8c0; --text-muted:#8888a8; --text-dim:#5a5a78;
  --accent-green:#00e5a0; --accent-green-rgb:0 229 160;
  --accent-blue:#3b82f6; --accent-blue-rgb:59 130 246;
  --accent-yellow:#f5d000; --accent-yellow-rgb:245 208 0;
  --accent-red:#ff4560; --accent-red-rgb:255 69 96;
  --accent-purple:#c084fc; --accent-purple-rgb:192 132 252;
  --accent-cyan:#22d3ee; --accent-cyan-rgb:34 211 238;
  --accent-identity:var(--accent-purple); --accent-identity-rgb:var(--accent-purple-rgb);
  --font-display:'Bebas Neue','Oswald','Arial Narrow',sans-serif;
  --font-body:'DM Sans',system-ui,sans-serif;
  --font-mono:'JetBrains Mono','Fira Code','SF Mono',monospace;
  --fs-hero:clamp(40px,8vw,92px); --fs-h1:clamp(30px,5vw,52px); --fs-h2:clamp(24px,3.4vw,34px);
  --fs-h3:20px; --fs-lg:18px; --fs-base:15px; --fs-sm:13px; --fs-xs:12px; --fs-label:11px; --fs-micro:10px;
  --sp-1:4px; --sp-2:8px; --sp-3:12px; --sp-4:16px; --sp-5:20px; --sp-6:24px; --sp-8:32px; --sp-10:40px; --sp-12:48px; --sp-16:64px; --sp-20:80px;
  --r-xs:3px; --r-sm:6px; --r-md:10px; --r-lg:12px; --r-xl:16px; --r-pill:9999px;
  --dur-fast:150ms; --dur-base:250ms; --dur-entry:650ms; --ease-out:cubic-bezier(0.16,1,0.3,1);
  --sbw:270px;
}
[data-theme="light"]{
  --bg:#faf9fc; --surface:#f1eff6; --card:#ffffff; --border:#dcd7e6; --hairline:rgba(0,0,0,0.05);
  --text-primary:#14101f; --text-secondary:#3a3450; --text-muted:#6a6480; --text-dim:#9a94ae;
  --accent-green:#008060; --accent-green-rgb:0 128 96;
  --accent-blue:#1d4ed8; --accent-blue-rgb:29 78 216;
  --accent-yellow:#936a00; --accent-yellow-rgb:147 106 0;
  --accent-red:#c41e3a; --accent-red-rgb:196 30 58;
  --accent-purple:#7c3aed; --accent-purple-rgb:124 58 237;
  --accent-cyan:#0e7490; --accent-cyan-rgb:14 116 144;
}
*,*::before,*::after{box-sizing:border-box}
html{-webkit-text-size-adjust:100%; scroll-behavior:smooth}
body{margin:0; background:var(--bg); color:var(--text-primary); font-family:var(--font-body); font-size:var(--fs-base); line-height:1.6; min-height:100vh; -webkit-font-smoothing:antialiased;
  transition:background var(--dur-base) var(--ease-out), color var(--dur-base) var(--ease-out);}
body::before{content:''; position:fixed; inset:0; background-image:
  repeating-linear-gradient(0deg,transparent 0 43px,var(--hairline) 43px 44px),
  repeating-linear-gradient(90deg,transparent 0 43px,var(--hairline) 43px 44px);
  z-index:0; pointer-events:none;}
.numeric,table td,table th,.mono,code,pre,input[type=number]{font-variant-numeric:tabular-nums lining-nums}
a{color:var(--accent-cyan); text-decoration:none} a:hover{text-decoration:underline}
:focus-visible{outline:2px solid var(--accent-identity); outline-offset:2px; border-radius:var(--r-xs)}
h2,h3{scroll-margin-top:var(--sp-10)}

.reading-progress{position:fixed; top:0; left:0; right:0; height:3px; background:transparent; z-index:1200; pointer-events:none}
.reading-progress-fill{height:100%; width:0%; background:linear-gradient(90deg,var(--accent-identity),var(--accent-cyan)); transition:width 60ms linear}

.sb-toggle{position:fixed; top:14px; left:14px; z-index:1150; width:44px; height:44px; display:grid; place-items:center;
  background:var(--card); border:1px solid var(--border); border-radius:var(--r-sm); cursor:pointer; color:var(--text-primary);
  transition:border-color var(--dur-fast), background var(--dur-fast)}
.sb-toggle:hover{border-color:var(--accent-identity)}
.sb-toggle svg{width:20px; height:20px}
.sidebar{position:fixed; top:0; left:0; bottom:0; width:var(--sbw); background:var(--surface); border-right:1px solid var(--border);
  z-index:1140; transform:translateX(-100%); transition:transform var(--dur-base) var(--ease-out); display:flex; flex-direction:column; overflow:hidden}
body.nav-open .sidebar{transform:translateX(0)}
.sb-head{padding:18px 20px 14px; border-bottom:1px solid var(--border)}
.sb-brand{font-family:var(--font-display); font-size:22px; letter-spacing:.04em; line-height:1; display:flex; align-items:center; gap:10px}
.sb-brand .mk{display:grid; place-items:center; width:26px; height:26px; background:var(--accent-identity); color:var(--bg); border-radius:var(--r-sm); font-size:16px}
.sb-brand span{color:var(--accent-identity)}
.sb-prog{margin-top:12px; font-family:var(--font-mono); font-size:var(--fs-micro); letter-spacing:.14em; text-transform:uppercase; color:var(--text-dim); display:flex; justify-content:space-between; align-items:center}
.sb-prog b{color:var(--accent-identity); font-weight:500}
.sb-bar{height:4px; background:var(--card); border-radius:var(--r-pill); overflow:hidden; margin-top:6px}
.sb-bar i{display:block; height:100%; width:0%; background:var(--accent-identity); transition:width 80ms linear}
.sb-nav{flex:1; overflow-y:auto; padding:10px 10px 24px}
.sb-link{display:flex; gap:11px; align-items:baseline; padding:9px 11px; border-radius:var(--r-sm); color:var(--text-muted);
  border-left:2px solid transparent; margin-bottom:2px; cursor:pointer; transition:color var(--dur-fast), background var(--dur-fast), border-color var(--dur-fast); font-size:var(--fs-sm)}
.sb-link .k{font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-dim); min-width:18px}
.sb-link:hover{color:var(--text-primary); background:var(--hairline)}
.sb-link.active{color:var(--text-primary); background:rgba(var(--accent-identity-rgb),.10); border-left-color:var(--accent-identity)}
.sb-link.active .k{color:var(--accent-identity)}
.sb-link.done .k::after{content:' ✓'; color:var(--accent-green)}
.sb-foot{padding:12px 20px; border-top:1px solid var(--border); display:flex; gap:8px}
.backdrop{position:fixed; inset:0; background:rgba(0,0,0,.55); z-index:1130; opacity:0; visibility:hidden; transition:opacity var(--dur-base)}
body.nav-open .backdrop{opacity:1; visibility:visible}
@media(min-width:1025px){
  body.nav-open .backdrop{display:none}
  body.nav-open .page{margin-left:var(--sbw)}
  .page{transition:margin-left var(--dur-base) var(--ease-out)}
}

.page{position:relative; z-index:1}
.container{width:100%; max-width:1000px; margin-inline:auto; padding-inline:clamp(var(--sp-4),4vw,var(--sp-10))}
.page-head{padding:var(--sp-20) 0 var(--sp-10)}
.eyebrow{font-family:var(--font-mono); font-size:var(--fs-label); letter-spacing:.22em; color:var(--accent-identity); text-transform:uppercase}
.title{font-family:var(--font-display); font-size:var(--fs-hero); line-height:.92; margin:.18em 0 .12em; letter-spacing:.01em}
.title span{color:var(--accent-identity)}
.subtitle{font-weight:300; font-size:var(--fs-lg); color:var(--text-secondary); max-width:60ch; line-height:1.65}
.subtitle b{color:var(--text-primary); font-weight:500}
.meta{font-family:var(--font-mono); font-size:var(--fs-label); color:var(--text-dim); letter-spacing:.1em; text-transform:uppercase; margin-top:var(--sp-5)}
.meta b{color:var(--accent-yellow); font-weight:400}

.audio-cta{display:flex; flex-wrap:wrap; align-items:center; gap:14px; margin-top:var(--sp-8); padding:16px 20px;
  background:rgba(var(--accent-identity-rgb),.06); border:1px solid rgba(var(--accent-identity-rgb),.22); border-radius:var(--r-md)}
.audio-cta .ico{font-size:22px}
.audio-cta p{margin:0; font-size:var(--fs-sm); color:var(--text-secondary); max-width:none}
.audio-cta.on{background:rgba(var(--accent-green-rgb),.06); border-color:rgba(var(--accent-green-rgb),.22)}

section.concept{padding:var(--sp-12) 0; border-top:1px solid var(--border)}
.sec-eyebrow{font-family:var(--font-mono); font-size:var(--fs-label); letter-spacing:.18em; text-transform:uppercase; color:var(--accent-identity)}
h2{font-family:var(--font-display); font-size:var(--fs-h2); letter-spacing:.02em; margin:.25em 0 .5em; line-height:1.05; font-weight:400}
h3{font-family:var(--font-body); font-size:var(--fs-h3); font-weight:600; margin:var(--sp-8) 0 var(--sp-3)}
.lead{font-size:var(--fs-lg); color:var(--text-secondary); max-width:64ch; line-height:1.7}
p{max-width:68ch}
strong,b{color:var(--text-primary); font-weight:600}
em{color:var(--accent-identity); font-style:normal}
.muted{color:var(--text-muted)}

.overview{padding:var(--sp-8) 0 var(--sp-4)}
.overview-map{list-style:none; padding:0; margin:var(--sp-6) 0 0; display:grid; gap:var(--sp-2); grid-template-columns:1fr 1fr}
@media(max-width:640px){.overview-map{grid-template-columns:1fr}}
.overview-map a{display:flex; gap:12px; align-items:baseline; padding:10px 12px; border-left:2px solid transparent; color:var(--text-muted); border-radius:var(--r-sm); transition:.15s}
.overview-map a:hover{color:var(--text-primary); border-left-color:var(--accent-identity); background:rgba(var(--accent-identity-rgb),.06); text-decoration:none}
.overview-map .mk{font-family:var(--font-mono); font-size:var(--fs-sm); color:var(--accent-identity); min-width:2em}

.card{background:var(--card); border:1px solid var(--border); border-radius:var(--r-md); padding:var(--sp-6)}
.demo{background:var(--surface); border:1px solid var(--border); border-radius:var(--r-lg); padding:var(--sp-6); margin:var(--sp-6) 0}
.demo-label{font-family:var(--font-mono); font-size:var(--fs-label); letter-spacing:.14em; text-transform:uppercase; color:var(--text-dim); display:flex; align-items:center; gap:8px; margin-bottom:var(--sp-5)}
.demo-label::before{content:'▸'; color:var(--accent-identity)}
.grid2{display:grid; grid-template-columns:1fr 1fr; gap:var(--sp-4)}
@media(max-width:640px){.grid2{grid-template-columns:1fr}}

.note-box{border-left:3px solid var(--accent-blue); background:rgba(var(--accent-blue-rgb),.06); padding:14px 18px; border-radius:0 var(--r-sm) var(--r-sm) 0; margin:var(--sp-5) 0}
.warning{border-left:3px solid var(--accent-yellow); background:rgba(var(--accent-yellow-rgb),.07); padding:14px 18px; border-radius:0 var(--r-sm) var(--r-sm) 0; margin:var(--sp-5) 0}
.warning .tag,.note-box .tag{font-family:var(--font-mono); font-size:var(--fs-label); letter-spacing:.12em; text-transform:uppercase; display:block; margin-bottom:4px}
.warning .tag{color:var(--accent-yellow)} .note-box .tag{color:var(--accent-blue)}
.warning p,.note-box p{margin:0; font-size:var(--fs-sm); color:var(--text-secondary); max-width:none}

.key-def{border:1px solid rgba(var(--accent-green-rgb),.25); background:rgba(var(--accent-green-rgb),.05); border-radius:var(--r-md); padding:16px 18px; margin:var(--sp-5) 0}
.key-def .tag{font-family:var(--font-mono); font-size:var(--fs-label); letter-spacing:.12em; text-transform:uppercase; color:var(--accent-green); display:block; margin-bottom:6px}

.formula{font-family:var(--font-mono); background:var(--card); border:1px solid var(--border); border-radius:var(--r-sm); padding:12px 16px; margin:var(--sp-4) 0; font-size:var(--fs-base); color:var(--text-primary); overflow-x:auto; max-width:none}
.formula .op{color:var(--accent-identity)}

.btn{display:inline-flex; align-items:center; justify-content:center; gap:8px; font-family:var(--font-body); font-weight:500; font-size:var(--fs-sm);
  padding:10px 16px; min-height:40px; border-radius:var(--r-sm); border:1px solid var(--border); background:var(--card); color:var(--text-primary); cursor:pointer;
  transition:.15s; user-select:none}
.btn:hover{border-color:var(--accent-identity); color:var(--accent-identity)}
.btn:active{transform:translateY(1px)}
.btn.primary{background:var(--accent-identity); color:var(--bg); border-color:var(--accent-identity)}
.btn.primary:hover{filter:brightness(1.08); color:var(--bg)}
.btn.sm{min-height:32px; padding:6px 12px; font-size:var(--fs-xs)}
.btn svg{width:15px; height:15px}
.btn.playing{background:var(--accent-red); border-color:var(--accent-red); color:#fff}
.btn-row{display:flex; flex-wrap:wrap; gap:8px; margin:var(--sp-4) 0}

.seg{display:inline-flex; background:var(--card); border:1px solid var(--border); border-radius:var(--r-sm); padding:3px; gap:2px}
.seg button{border:0; background:transparent; color:var(--text-muted); font-family:var(--font-mono); font-size:var(--fs-xs); padding:6px 12px; border-radius:var(--r-xs); cursor:pointer; transition:.12s}
.seg button.on{background:var(--accent-identity); color:var(--bg)}

.range-row{display:flex; align-items:center; gap:14px; margin:var(--sp-3) 0}
.range-row label{font-size:var(--fs-sm); color:var(--text-muted); min-width:96px}
.range-row .rv{font-family:var(--font-mono); font-size:var(--fs-sm); color:var(--text-primary); background:var(--card); border:1px solid var(--border); padding:2px 10px; border-radius:var(--r-sm); min-width:64px; text-align:center}
input[type=range]{-webkit-appearance:none; appearance:none; flex:1; height:4px; border-radius:4px; background:var(--border); outline:none; cursor:pointer}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none; width:16px; height:16px; border-radius:50%; background:var(--accent-identity); border:3px solid var(--bg); box-shadow:0 0 0 1px var(--accent-identity)}
input[type=range]::-moz-range-thumb{width:13px; height:13px; border-radius:50%; background:var(--accent-identity); border:3px solid var(--bg)}

table{width:100%; border-collapse:collapse; margin:var(--sp-5) 0; font-size:var(--fs-sm)}
th,td{text-align:left; padding:9px 12px; border-bottom:1px solid var(--border)}
th{font-family:var(--font-mono); font-size:var(--fs-xs); letter-spacing:.06em; text-transform:uppercase; color:var(--text-muted); font-weight:500}
td{color:var(--text-secondary)}
td b{color:var(--text-primary)}
tr:hover td{background:var(--hairline)}
.table-wrap{overflow-x:auto; border:1px solid var(--border); border-radius:var(--r-md)}
.table-wrap table{margin:0}
.table-wrap th,.table-wrap td:first-child{white-space:nowrap}

details{border:1px solid var(--border); border-radius:var(--r-sm); margin:var(--sp-4) 0; background:var(--card); overflow:hidden}
details summary{cursor:pointer; padding:12px 16px; font-family:var(--font-mono); font-size:var(--fs-sm); color:var(--accent-identity); list-style:none; display:flex; align-items:center; gap:10px; user-select:none}
details summary::-webkit-details-marker{display:none}
details summary::before{content:'+'; font-size:16px; width:16px; color:var(--accent-identity)}
details[open] summary::before{content:'–'}
details summary:hover{background:var(--hairline)}
.details-body{padding:2px 18px 18px; font-size:var(--fs-sm); color:var(--text-secondary); border-top:1px solid var(--border)}
.details-body p{max-width:none}

.piano-wrap{overflow-x:auto; padding-bottom:6px}
.piano{position:relative; display:flex; height:170px; min-width:560px; user-select:none; touch-action:manipulation}
.wkey{position:relative; flex:1; background:linear-gradient(180deg,#f6f6fb,#dcdce6); border:1px solid #23232e; border-top:none; border-radius:0 0 6px 6px; cursor:pointer; display:flex; align-items:flex-end; justify-content:center; padding-bottom:8px; transition:background .05s}
.wkey:active,.wkey.down{background:linear-gradient(180deg,#c9b8ff,#a988f0)}
.wkey .lbl{font-family:var(--font-mono); font-size:10px; color:#33333f; text-align:center; line-height:1.2; pointer-events:none}
.wkey .lbl .vn{display:block; font-size:9px; color:#6a6a7a}
.bkey{position:absolute; top:0; height:62%; background:linear-gradient(180deg,#2a2a38,#0e0e16); border:1px solid #000; border-radius:0 0 5px 5px; z-index:3; cursor:pointer; transform:translateX(-50%)}
.bkey:active,.bkey.down{background:linear-gradient(180deg,#8f6fe0,#6a4bc0)}
.bkey .lbl{position:absolute; bottom:6px; left:0; right:0; font-family:var(--font-mono); font-size:8px; color:#c9c9d6; text-align:center; pointer-events:none}

.staff-box{display:flex; align-items:center; gap:16px; flex-wrap:wrap}
.staff{background:var(--card); border:1px solid var(--border); border-radius:var(--r-sm); padding:10px}
.now-note{font-family:var(--font-display); font-size:40px; color:var(--accent-identity); line-height:1; min-width:120px}
.now-note small{display:block; font-family:var(--font-mono); font-size:12px; color:var(--text-muted); margin-top:4px}

.readout{font-family:var(--font-mono); font-size:var(--fs-sm); color:var(--text-secondary); background:var(--card); border:1px solid var(--border); border-radius:var(--r-sm); padding:10px 14px; margin-top:12px; min-height:44px; max-width:none}
.readout b{color:var(--accent-identity)}

.seq-grid{display:grid; gap:4px; margin-top:12px}
.seq-row{display:grid; grid-template-columns:64px 1fr; gap:8px; align-items:center}
.seq-row .rl{font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted)}
.seq-cells{display:grid; gap:3px}
.cell{height:20px; border-radius:3px; background:var(--card); border:1px solid var(--border)}
.cell.beat{border-color:#3a3a4e}
.cell.on-k{background:var(--accent-red)} .cell.on-s{background:var(--accent-yellow)} .cell.on-h{background:var(--accent-cyan)} .cell.on-b{background:var(--accent-green)} .cell.on-c{background:var(--accent-identity)}
.cell.play{outline:2px solid #fff; outline-offset:-1px}
.seq-legend{display:flex; gap:14px; flex-wrap:wrap; font-family:var(--font-mono); font-size:var(--fs-xs); color:var(--text-muted); margin-top:10px}
.seq-legend i{display:inline-block; width:11px; height:11px; border-radius:2px; margin-right:5px; vertical-align:-1px}

.pulse-row{display:flex; gap:8px; margin:14px 0}
.pdot{flex:1; height:46px; border-radius:var(--r-sm); background:var(--card); border:1px solid var(--border); display:grid; place-items:center; font-family:var(--font-mono); font-size:var(--fs-sm); color:var(--text-muted); transition:background .05s, color .05s}
.pdot.strong{border-color:rgba(var(--accent-identity-rgb),.4)}
.pdot.hit{background:var(--accent-identity); color:var(--bg)}
.pdot.hit.strong{background:var(--accent-cyan)}
.tap-btn{width:100%; min-height:90px; font-size:18px; font-family:var(--font-display); letter-spacing:.05em}
.tap-fb{font-family:var(--font-mono); font-size:var(--fs-sm); margin-top:10px; min-height:44px; display:flex; align-items:center; gap:10px; flex-wrap:wrap}
.tap-fb .val{padding:3px 10px; border-radius:var(--r-sm); font-weight:600}
.fb-tight{background:rgba(var(--accent-green-rgb),.15); color:var(--accent-green)}
.fb-early{background:rgba(var(--accent-cyan-rgb),.15); color:var(--accent-cyan)}
.fb-late{background:rgba(var(--accent-yellow-rgb),.15); color:var(--accent-yellow)}

.cof-wrap{display:grid; grid-template-columns:1fr 260px; gap:var(--sp-6); align-items:center}
@media(max-width:720px){.cof-wrap{grid-template-columns:1fr}}
.cof-svg{width:100%; max-width:360px; margin-inline:auto; display:block}
.cof-seg{cursor:pointer}
.cof-seg text{font-family:var(--font-mono); pointer-events:none}
.cof-info h4{margin:0 0 4px; font-family:var(--font-display); font-size:28px; color:var(--accent-identity); font-weight:400; letter-spacing:.02em}
.cof-info .row{display:flex; justify-content:space-between; padding:7px 0; border-bottom:1px solid var(--border); font-size:var(--fs-sm)}
.cof-info .row span:first-child{color:var(--text-muted)} .cof-info .row span:last-child{font-family:var(--font-mono); color:var(--text-primary)}

.quiz{background:var(--surface); border:1px solid var(--border); border-radius:var(--r-lg); padding:var(--sp-6)}
.quiz-q{font-size:var(--fs-lg); margin:6px 0 14px}
.quiz-opts{display:grid; grid-template-columns:repeat(auto-fill,minmax(120px,1fr)); gap:8px}
.qopt{padding:12px; border:1px solid var(--border); border-radius:var(--r-sm); background:var(--card); cursor:pointer; text-align:center; font-family:var(--font-mono); font-size:var(--fs-sm); transition:.12s}
.qopt:hover{border-color:var(--accent-identity)}
.qopt.correct{background:rgba(var(--accent-green-rgb),.16); border-color:var(--accent-green); color:var(--accent-green)}
.qopt.wrong{background:rgba(var(--accent-red-rgb),.16); border-color:var(--accent-red); color:var(--accent-red)}
