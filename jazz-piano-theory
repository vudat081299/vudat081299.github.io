/* ===== 07. REHARMONIZATION CATALOG ===== */
(function(){
  const wrap=document.getElementById('rh1Btns'), ro=document.getElementById('rh1Readout'),
        bpm=document.getElementById('rh1Bpm'), bpmV=document.getElementById('rh1BpmV');
  if(!wrap) return; if(bpm) bpm.addEventListener('input',()=>bpmV.textContent=bpm.value+' BPM');
  // voicing library {b: bass, up:[...]}
  const L={
    Cmaj7:{b:48,up:[64,67,71,74]}, Dm7:{b:50,up:[60,65,69,72]}, G7:{b:43,up:[59,62,65,67]},
    Db7:{b:49,up:[65,67,68,71]}, Am7:{b:45,up:[60,64,67,71]}, A7:{b:45,up:[61,64,67,71]},
    Fmaj7:{b:53,up:[57,60,64,67]}, Fm7:{b:53,up:[56,60,63,67]}, Bb7:{b:46,up:[62,65,68,72]},
    Cdim:{b:49,up:[52,55,58,61]}, Ebm7:{b:51,up:[54,58,61,65]}, Cmaj7b:{b:48,up:[60,64,67,71]}
  };
  const items=[
    {label:'Tritone sub', before:['Dm7','G7','Cmaj7'], after:['Dm7','Db7','Cmaj7'],
      desc:'<b>Tritone sub.</b> Thay G7 → D♭7 (cùng cặp guide tone F–B). Bass trượt <b>D♭→C</b> nửa cung, nghe cực trơn.'},
    {label:'Secondary dominant', before:['Cmaj7','Am7','Dm7','G7'], after:['Cmaj7','A7','Dm7','G7'],
      desc:'<b>Secondary dominant.</b> Am7 → A7 (= V7 của Dm). Mượn lực kéo tạm tới Dm — vòng "đi" hơn hẳn.'},
    {label:'Chèn ii–V', before:['Cmaj7','Cmaj7'], after:['Dm7','G7','Cmaj7'],
      desc:'<b>Chèn ii–V.</b> Một ô Cmaj7 đứng yên → lấp bằng Dm7–G7 dẫn về chính nó. Chỗ tĩnh hoá chỗ "đi".'},
    {label:'Modal interchange', before:['Cmaj7','Fmaj7','Cmaj7'], after:['Cmaj7','Fm7','Cmaj7'],
      desc:'<b>Modal interchange.</b> IV (Fmaj7) → iv thứ (Fm7) mượn từ Đô thứ. Cú "chùng xuống" nao lòng — rất hay trong ballad.'},
    {label:'Backdoor ii–V', before:['Dm7','G7','Cmaj7'], after:['Fm7','Bb7','Cmaj7'],
      desc:'<b>Backdoor ii–V.</b> Về I qua "cửa sau": Fm7–B♭7 (ii–V mượn của Đô thứ) thay front-door. Màu soul/nhạc phim.'},
    {label:'Dim passing', before:['Cmaj7b','Dm7'], after:['Cmaj7b','Cdim','Dm7'],
      desc:'<b>Dim passing.</b> Chèn C♯°7 nối C lên Dm. Bass đi từng bước C–C♯–D, hợp âm giảm làm cầu mượt.'},
    {label:'Chromatic approach', before:['Cmaj7b','Dm7'], after:['Cmaj7b','Ebm7','Dm7'],
      desc:'<b>Chromatic approach.</b> E♭m7 (cách Dm7 nửa cung phía trên) rồi trượt xuống — "tiếp cận từ trên", rất jazz.'},
    {label:'Pedal point', pedal:true,
      beforeCh:[{b:48,up:[64,67,71]},{b:43,up:[62,65,71]},{b:45,up:[64,67,72]},{b:53,up:[65,69,72]}],
      afterCh:[{b:48,up:[64,67,71]},{b:48,up:[62,65,71]},{b:48,up:[64,67,72]},{b:48,up:[65,69,72]}],
      desc:'<b>Pedal point.</b> Cùng chuỗi hợp âm; bản sau <b>giữ nguyên bass Đô</b>. Nghe căng &amp; "dính" vào một trọng tâm — hay dùng mở/kết bài.'},
    {label:'Coltrane (nâng cao)', seq:[[60,64,67,71],[63,67,70,73],[56,60,63,67],[59,63,66,69],[64,68,71,75],[55,59,62,65],[60,64,67,71]],
      desc:'<b>Coltrane changes.</b> Chuyển chủ âm theo quãng 3 trưởng (C→A♭→E→C), nối bằng dominant. Đỉnh của reharm — để dành khi đã vững cơ bản.'}
  ];
  function playBA(before, after, spb){
    const t0=audio().currentTime+0.05, bstep=spb*2;
    for(let i=0;i<before.length;i++){ const c=before[i], t=t0+i*bstep; voice(c.b,t,bstep*0.95,0.5); chord(c.up,t,bstep*0.9,0.58); }
    const gap=before.length*bstep + spb*1.1;
    for(let i=0;i<after.length;i++){ const c=after[i], t=t0+gap+i*bstep; voice(c.b,t,bstep*0.95,0.5); chord(c.up,t,bstep*0.9,0.58); }
  }
  mkBtns('rh1Btns', items, function(it){
    const spb=60/(+bpm.value);
    if(it.seq){ const t0=audio().currentTime+0.05; for(let i=0;i<it.seq.length;i++){ const t=t0+i*spb*1.1; voice(it.seq[i][0]-12,t,spb*1.05,0.45); chord(it.seq[i],t,spb*1.0,0.55); } ro.innerHTML=it.desc; return; }
    let before, after;
    if(it.pedal){ before=it.beforeCh; after=it.afterCh; }
    else { before=it.before.map(function(n){return L[n];}); after=it.after.map(function(n){return L[n];}); }
    playBA(before, after, spb);
    ro.innerHTML='🔻 TRƯỚC → SAU · '+it.desc;
  });
})();

/* ===== 08. FORMS: JAZZ BLUES + RHYTHM CHANGES ===== */
(function(){
  const V={
    C7:{b:48,up:[64,67,70]}, F7:{b:41,up:[57,60,63]}, Gm7:{b:43,up:[58,62,65]},
    Fs0:{b:42,up:[54,57,60,63]}, A7:{b:45,up:[61,64,67]}, Dm7:{b:50,up:[60,65,69]}, G7:{b:43,up:[59,62,65]},
    Cmaj7:{b:48,up:[64,67,71]}, C6:{b:48,up:[64,67,69]}, Em7:{b:52,up:[55,59,62,66]}, Fmaj7:{b:53,up:[57,60,64]}, Fm7:{b:53,up:[56,60,63]},
    E7:{b:52,up:[56,59,62,66]}, D7:{b:50,up:[54,57,60,64]}, A7b:{b:45,up:[61,64,67,71]}, G7b:{b:43,up:[59,62,65,69]}
  };
  const blues=[['C7',2],['F7',2],['C7',2],['Gm7',1],['C7',1],['F7',2],['Fs0',2],['C7',2],['A7',2],['Dm7',2],['G7',2],['C7',1],['A7',1],['Dm7',1],['G7',1]];
  const rcA=[['C6',1],['A7',1],['Dm7',1],['G7',1],['Em7',1],['A7',1],['Dm7',1],['G7',1],['C7',1],['C7',1],['Fmaj7',1],['Fm7',1],['Cmaj7',1],['A7',1],['Dm7',1],['G7',1]];
  const rcB=[['E7',4],['A7b',4],['D7',4],['G7b',4]];
  let timers=[], curBtn=null;
  function stop(){ timers.forEach(clearTimeout); timers=[]; if(curBtn){setPlaying(curBtn,false);curBtn=null;} }
  function play(list, bpm, btn){
    stop(); audio(); markAudioOn(); curBtn=btn; setPlaying(btn,true);
    const spb=60/bpm; let acc=0;
    list.forEach(function(item){ const ch=V[item[0]], beats=item[1], delay=acc*spb*1000;
      timers.push(setTimeout(function(){ const t=audio().currentTime+0.02; voice(ch.b,t,beats*spb*0.95,0.5); chord(ch.up,t,beats*spb*0.9,0.56); }, delay));
      acc+=beats;
    });
    timers.push(setTimeout(function(){ setPlaying(btn,false); curBtn=null; }, acc*spb*1000+200));
  }
  const bp=document.getElementById('bluesPlay'), bs=document.getElementById('bluesStop');
  if(bp){ bp.addEventListener('click',function(){ if(curBtn===bp){stop();return;} play(blues,120,bp); }); bs.addEventListener('click',stop); }
  const a=document.getElementById('rcA'), b=document.getElementById('rcB'), s=document.getElementById('rcStop');
  if(a){ a.addEventListener('click',function(){ if(curBtn===a){stop();return;} play(rcA,140,a); });
    b.addEventListener('click',function(){ if(curBtn===b){stop();return;} play(rcB,140,b); }); s.addEventListener('click',stop); }
})();

